{
	"name": "n8n-nodes-gitea-full",
	"version": "0.2.0",
	"description": "n8n node for Gitea",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"gitea"
	],
	"author": {
		"name": "sungaowei",
		"email": "guchengod@sina.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/sungaowei/n8n-nodes-gitea-full.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
